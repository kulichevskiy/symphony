# Secrets — pydantic-settings reads .env natively; never commit.
.env
.env.*
!.env.example

# Python build / cache
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# uv
.venv/

# Local SQLite + log artefacts when running on a dev machine
*.sqlite
*.sqlite-journal
state.sqlite-wal
state.sqlite-shm
state.sqlite
logs/
workspaces/

# Frontend local deps / production build output
node_modules/
frontend/node_modules/
frontend/dist/
frontend/*.tsbuildinfo
frontend/vite.config.d.ts
frontend/vite.config.js

# Local backup files (e.g. state.sqlite.<ts>.bak, workspaces.<ts>.bak/)
*.bak
*.bak/

# Local operator config / tool state
config.local.yaml
.claude/*
# …except shared project skills, which are version-controlled
!.claude/skills/
.agents/

# Symphony runtime state — event log + checked-out worktrees
.symphony/

# Design notes / research — kept locally, not tracked
docs/
analysis/

# OS
.DS_Store

# Project uses pnpm; npm lockfiles should never be tracked
frontend/package-lock.json
