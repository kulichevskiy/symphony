# Copy to `.env` in this directory. `.env` is gitignored.
# pydantic-settings reads this file at startup.

LINEAR_API_KEY=lin_api_paste_here

# Webhook HMAC verification secret (Linear → Cloudflare Tunnel → /webhook).
# Generate once: `openssl rand -hex 32`
LINEAR_WEBHOOK_SECRET=

# Optional: explicit GH token. If unset, falls back to `gh auth token`.
# GH_TOKEN=

# Auth0 gate for the /api/* surface (SPA ID-token path — no custom API audience).
# All three must be set to enable the gate; leave blank to disable it.
# AUTH0_CLIENT_ID is the SPA app client_id, matched against the ID token `aud`.
# AUTH0_ALLOWED_EMAILS is a comma-separated allowlist matched against `email`.
AUTH0_DOMAIN=
AUTH0_CLIENT_ID=
AUTH0_ALLOWED_EMAILS=

# Telegram push on attention-needed events (operator-wait / run failure / PR
# merged). Both must be set to enable; leave either blank to disable.
# Bot token from @BotFather; chat id is the target user/group/channel.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
