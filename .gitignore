# Secrets — pydantic-settings reads .env natively; never commit.
.env
.env.*
!.env.example

# Python build / cache
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# uv
.venv/

# Local SQLite + log artefacts when running on a dev machine
*.sqlite
*.sqlite-journal
state.sqlite
logs/
workspaces/

# Local backup files (e.g. state.sqlite.<ts>.bak, workspaces.<ts>.bak/)
*.bak
*.bak/

# Local operator config / tool state
config.local.yaml
.claude/

# OS
.DS_Store
